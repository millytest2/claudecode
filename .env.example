# ── Required ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Reddit (optional — scanner works without these via public JSON API) ──────
# Create an app at https://www.reddit.com/prefs/apps
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=MoneyAgent/1.0

# ── Agent behaviour ──────────────────────────────────────────────────────────
# How often to scan (in loop mode)
SCAN_INTERVAL_MINUTES=30

# Max opportunities shown per scan cycle
MAX_OPPORTUNITIES_PER_SCAN=10

# Minimum Claude score (0–10) to surface an opportunity
MIN_SCORE_THRESHOLD=6.5

# Where generated proposals/plans/content are saved
OUTPUT_DIR=./output
